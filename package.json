{
  "name": "clic-frontend-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "install:all": "npm install",
    "dev:chatbot": "npm run dev -w apps/chatbot",
    "dev:graph": "npm run dev -w apps/graph-builder",
    "build:all": "npm run build -w apps/chatbot && npm run build -w apps/graph-builder"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.25",
    "vue-i18n": "^11.4.4"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitejs/plugin-vue": "^6.0.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.5"
  }
}
