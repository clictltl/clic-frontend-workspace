{
  "name": "@clic/chatbot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:github": "vue-tsc -b && vite build --mode github",
    "build:wordpress": "vue-tsc -b && vite build --mode production",
    "build:offline": "vite build --mode offline",
    "build:pwa": "vite build --mode pwa",
    "build": "npm run build:wordpress",
    "preview": "vite preview",
    "deploy": "npm run build:github && touch dist/.nojekyll",
    "deploy:pwa": "npm run build:pwa && rsync -av --delete --exclude='.git' --exclude='.nojekyll' --exclude='README.md' dist-pwa/ ../../../novelo-pwa/",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@clic/shared": "*",
    "@emoji-mart/data": "^1.2.1",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@tiptap/vue-3": "^3.22.5",
    "browser-image-compression": "^2.0.2",
    "emoji-mart": "^5.6.0",
    "file-type": "^22.0.1",
    "jszip": "^3.10.1",
    "leader-line-new": "^1.1.9"
  },
  "devDependencies": {
    "@types/jszip": "^3.4.0"
  }
}
