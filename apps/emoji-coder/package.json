{
  "name": "@clic/emoji-coder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:github": "vue-tsc && vite build --mode github",
    "build:offline": "vite build --mode offline",
    "build:pwa": "vite build --mode pwa",
    "deploy": "npm run build:github && touch dist/.nojekyll",
    "deploy:pwa": "npm run build:pwa && rsync -av --delete --exclude='.git' --exclude='.nojekyll' --exclude='README.md' dist-pwa/ ../../../caramelo-pwa/",
    "preview": "vite preview"
  },
  "dependencies": {
    "@blockly/field-colour": "^6.0.12",
    "@clic/shared": "*",
    "@vueuse/core": "^14.2.1",
    "blockly": "^12.5.1"
  },
  "devDependencies": {
    "@vue/tsconfig": "^0.8.1"
  }
}
