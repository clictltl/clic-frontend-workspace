{
  "name": "@clic/graph-builder",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:github": "vue-tsc && vite build --mode github",
    "build:offline": "vite build --mode offline",
    "deploy": "npm run build:github && touch dist/.nojekyll",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clic/shared": "*",
    "@vueuse/core": "^14.2.1",
    "cytoscape": "^3.33.1",
    "jszip": "^3.10.1",
    "markdown-it": "^14.1.1",
    "sass": "^1.97.3",
    "uuid": "^13.0.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/jszip": "^3.4.0",
    "@types/markdown-it": "^14.1.2",
    "@types/uuid": "^10.0.0",
    "@vue/tsconfig": "^0.8.1"
  }
}
